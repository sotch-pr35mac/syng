{
	"name": "syng",
	"version": "2.0.0",
	"description": "An open source, cross platform, Chinese study app.",
	"scripts": {
		"build": "vite build",
		"typecheck": "svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint src/views",
		"fix-lint": "eslint src/views --fix",
		"format": "prettier --write \"src/views/**/*.{js,ts,svelte}\"",
		"format:check": "prettier --check \"src/views/**/*.{js,ts,svelte}\"",
		"test": "vitest run",
		"test-coverage": "vitest run --coverage"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/sotch-pr35mac/syng"
	},
	"author": "Preston Wang-Stosur-Bassett",
	"license": "GPL-3.0",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/svelte": "^5.0.0",
		"@testing-library/user-event": "^14.2.0",
		"@types/dompurify": "^3.0.5",
		"eslint": "^10.2.1",
		"eslint-plugin-promise": "^7.2.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^17.5.0",
		"jsdom": "^29.1.0",
		"lucide-svelte": "^1.0.1",
		"prettier": "^3.4.0",
		"prettier-plugin-svelte": "^3.3.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.4.6",
		"svelte-spa-router": "^5.1.0",
		"terser": "^5.44.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.9.1",
		"@tauri-apps/plugin-cli": "^2.4.1",
		"@tauri-apps/plugin-fs": "^2.4.4",
		"@tauri-apps/plugin-os": "^2.3.2",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-updater": "^2.9.0",
		"dompurify": "^3.3.3",
		"elastic-scroll-polyfill": "^2.1.0",
		"hanzi-writer": "^3.7.3",
		"marked": "^18.0.0"
	}
}
