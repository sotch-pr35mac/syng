{
	"identifier": "mobile-capability",
	"platforms": ["iOS", "android"],
	"windows": ["main"],
	"permissions": [
		"core:default",
		"fs:allow-read-file",
		"fs:allow-write-file",
		"fs:allow-read-dir",
		"fs:allow-copy-file",
		"fs:allow-mkdir",
		"fs:allow-remove",
		"fs:allow-rename",
		"fs:allow-exists",
		"fs:allow-appdata-read-recursive",
		"fs:allow-appdata-write-recursive",
		{ "identifier": "fs:scope", "allow": ["$APPDATA/**"] },
		"fs:default",
		"http:default",
		"notification:default",
		"os:allow-platform",
		"os:allow-version",
		"os:allow-os-type",
		"os:allow-family",
		"os:allow-arch",
		"os:allow-locale",
		"os:allow-hostname",
		"os:default",
		"clipboard-manager:allow-read-text",
		"clipboard-manager:allow-write-text",
		"shell:allow-open",
		"shell:default",
		"dialog:allow-open",
		"dialog:allow-save",
		"dialog:allow-ask",
		"dialog:allow-message",
		"dialog:allow-confirm",
		"process:allow-restart",
		"process:allow-exit"
	]
}
